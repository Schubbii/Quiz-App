{
  "name": "quiz-app",
  "version": "1.0.0",
  "description": "Arbeitet nie direkt auf main/master.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "app:dir": "electron-builder --dir",
    "app:dist": "electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Schubbii/Quiz-App.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Schubbii/Quiz-App/issues"
  },
  "homepage": "https://github.com/Schubbii/Quiz-App#readme",
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.p1.quizapp",
    "productName": "Quiz App",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
